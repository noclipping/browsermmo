generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CharacterClass {
  WARRIOR
  MAGE
  ROGUE
}

enum RogueSkill {
  VOLLEY
  DAGGER_STORM
  SHADOW
}

enum ItemSlot {
  WEAPON
  HELMET
  CHEST
  GLOVES
  BOOTS
  RING
  AMULET
  CONSUMABLE
}

enum SoloCombatStatus {
  ACTIVE
  VICTORY
  DEFEAT
}

enum EnemyIntent {
  ATTACK
  HEAVY_ATTACK
  GUARD
  RECOVER
  /** Normal damage turn (Slay-the-Spire-style: separate from buff turns). */
  STRIKE
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  GODLY
}

/** Directed friend request / friendship edge (async-only; no realtime). */
enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum GuildRole {
  OWNER
  OFFICER
  MEMBER
}

enum GuildInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum GuildBossSeasonStatus {
  ACTIVE
  DEFEATED
}

enum GuildBossAttemptStatus {
  PENDING
  COMPLETED
  VOIDED
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  email        String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  lastSeenAt   DateTime?
  sessions     Session[]
  characters   Character[]
  chatMessages ChatMessage[]
  friendshipsRequested Friendship[] @relation("FriendshipRequester")
  friendshipsReceived  Friendship[] @relation("FriendshipAddressee")
  guildOwned      Guild[]            @relation("GuildOwner")
  guildMembership GuildMember[]
  guildInvitesSent GuildInvite[]     @relation("GuildInviteInviter")
  guildInvitesReceived GuildInvite[] @relation("GuildInvitee")
  guildDonations  GuildDonation[]
  guildChatMessages GuildChatMessage[]
  guildBossAttempts      GuildBossAttempt[]
  guildBossContributions GuildBossContribution[]
  guildBossRewardClaims  GuildBossRewardClaim[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  channel   String   @default("world")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String
  text      String
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
}

model Friendship {
  id          String            @id @default(cuid())
  requesterId String
  requester   User              @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User              @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendshipStatus  @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model Guild {
  id          String    @id @default(cuid())
  emoji       String    @default("🛡️")
  /** Total guild progression XP (donations and future sources). Level is derived in code. */
  xp          Int       @default(0)
  name        String    @unique
  description String    @default("")
  ownerId     String
  owner       User      @relation("GuildOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members     GuildMember[]
  invites     GuildInvite[]
  donations   GuildDonation[]
  chatMessages GuildChatMessage[]
  bossSeasons GuildBossSeason[]
  guildBossAttempts      GuildBossAttempt[]
  guildBossContributions GuildBossContribution[]
  guildBossRewardClaims  GuildBossRewardClaim[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model GuildMember {
  id       String    @id @default(cuid())
  guildId  String
  guild    Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     GuildRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  @@unique([guildId, userId])
  @@index([guildId, role])
}

model GuildInvite {
  id        String            @id @default(cuid())
  guildId   String
  guild     Guild             @relation(fields: [guildId], references: [id], onDelete: Cascade)
  inviterId String
  inviter   User              @relation("GuildInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeId String
  invitee   User              @relation("GuildInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  status    GuildInviteStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([guildId, inviteeId])
  @@index([inviteeId, status])
  @@index([guildId, status])
}

model GuildDonation {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
  @@index([userId, createdAt])
}

model GuildChatMessage {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String
  text      String
  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
}

model GuildBossSeason {
  id                 String                @id @default(cuid())
  guildId            String
  guild              Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  bossKey            String
  maxHp              Int
  currentHp          Int
  memberCountAtStart Int
  status             GuildBossSeasonStatus @default(ACTIVE)
  startedAt          DateTime              @default(now())
  defeatedAt         DateTime?
  /** When an ACTIVE season becomes DEFEATED, set to now + cooldown; next boss spawns after this time (per guild). */
  nextSpawnAt        DateTime?
  attempts           GuildBossAttempt[]
  contributions      GuildBossContribution[]
  rewardClaims       GuildBossRewardClaim[]

  @@index([guildId, status])
}

model GuildBossAttempt {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildId   String
  guild     Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  seasonId  String
  season    GuildBossSeason       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  bossKey   String
  status    GuildBossAttemptStatus @default(PENDING)
  damageDealt Int                 @default(0)
  completedAt DateTime?
  soloCombatEncounter SoloCombatEncounter?

  @@index([userId, guildId, status, completedAt])
  @@index([seasonId])
}

model GuildBossContribution {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildId     String
  guild       Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
  seasonId    String
  season      GuildBossSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  damageTotal Int             @default(0)
  updatedAt   DateTime        @updatedAt

  @@unique([userId, seasonId])
}

model GuildBossRewardClaim {
  id                     String          @id @default(cuid())
  userId                 String
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildId                String
  guild                  Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
  seasonId               String
  season                 GuildBossSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  participationClaimedAt DateTime?
  /** @deprecated Legacy — superseded by raid chest gold; kept for history. */
  clearClaimedAt         DateTime?
  chestClaimedAt         DateTime?

  @@unique([userId, seasonId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Character {
  id             String               @id @default(cuid())
  name           String
  portraitKey    String?
  bio            String               @default("")
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  class          CharacterClass
  rogueSkill     RogueSkill           @default(VOLLEY)
  level          Int                  @default(1)
  xp             Int                  @default(0)
  hp             Int
  maxHp          Int
  attack         Int
  defense        Int
  speed          Int
  critChance     Float                @default(0.05)
  strength       Int                  @default(8)
  constitution   Int                  @default(8)
  intelligence   Int                  @default(8)
  dexterity      Int                  @default(8)
  statPoints     Int                  @default(0)
  gold           Int                  @default(0)
  /** Wins in Town Outskirts since last Sewer Fencer miniboss (victory only). */
  outskirtsWinsSinceBoss Int          @default(0)
  /** After this many outskirts wins, the next combat spawn is the miniboss. */
  outskirtsBossAt        Int          @default(4)
  /** Last time free town campfire rest was used (2m cooldown between uses). */
  lastFreeRestAt DateTime?
  regionId       String
  region         Region               @relation(fields: [regionId], references: [id])
  inventoryItems InventoryItem[]
  equipment      CharacterEquipment[]
  combatLogs     CombatLog[]
  soloCombats    SoloCombatEncounter[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([name])
}

model Region {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String
  minLevel    Int         @default(1)
  enemies     Enemy[]
  dungeons    Dungeon[]
  characters  Character[]
}

model Enemy {
  id            String   @id @default(cuid())
  key           String   @unique
  name          String
  emoji         String
  level         Int      @default(1)
  hp            Int
  attack        Int
  defense       Int
  speed         Int
  xpReward      Int
  goldMin       Int
  goldMax       Int
  regionId      String
  region        Region   @relation(fields: [regionId], references: [id])
  lootEntries   LootTableEntry[]
  bossFor       Dungeon[]
  combatLogs    CombatLog[]
  soloCombats   SoloCombatEncounter[]
  isDungeonBoss Boolean  @default(false)
  /** Tougher adventure spawn in the same region as normal critters. */
  isElite       Boolean  @default(false)
  /** Scripted miniboss for adventure pacing (e.g. Sewer Fencer). */
  isAdventureMiniBoss Boolean @default(false)
}

model SoloCombatEncounter {
  id                 String           @id @default(cuid())
  characterId        String
  character          Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  enemyId            String
  enemy              Enemy            @relation(fields: [enemyId], references: [id])
  /** When set, this fight is an async guild boss attempt (no solo XP/gold/drops). */
  guildBossAttemptId String?          @unique
  guildBossAttempt   GuildBossAttempt? @relation(fields: [guildBossAttemptId], references: [id], onDelete: SetNull)
  status             SoloCombatStatus @default(ACTIVE)
  playerHp           Int
  playerMaxHp        Int
  enemyHp            Int
  enemyMaxHp         Int
  playerAttack       Int
  playerDefense      Int
  playerSpeed        Int
  playerCrit         Float
  enemyAttack        Int
  enemyDefense       Int
  enemySpeed         Int
  enemyCrit          Float            @default(0.04)
  enemyIntent        EnemyIntent      @default(ATTACK)
  /** Consecutive offensive telegraphs (STRIKE/HEAVY_ATTACK), capped by roll rules. */
  enemyStrikeStreak       Int              @default(0)
  round                    Int              @default(1)
  skillCooldownRemaining   Int              @default(0)
  /** Remaining enemy actions that are negated by Shadow Veil. */
  playerInvulnerableTurns  Int              @default(0)
  /** Manual potion: turns before another tonic (does not tick during AUTO). */
  potionCooldownRemaining  Int              @default(0)
  playerIntelligence       Int              @default(0)
  playerDexterity          Int              @default(0)
  /** Fractional heal from damage dealt (0.05 = 5%). */
  playerLifeSteal          Float            @default(0)
  /** Multiplier bonus for skill attacks (0.2 = +20% skill power). */
  playerSkillPowerBonus    Float            @default(0)
  /** Multiplier applied to the enemy's next STRIKE / HEAVY_ATTACK (from Enrage). */
  enemyPendingDamageMult   Float            @default(1)
  /** Extra armor vs player damage until your next action resolves (from Harden). */
  enemyPendingArmorVsPlayer Int             @default(0)
  log                Json
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([characterId, status])
}

model Dungeon {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String
  minLevel    Int
  regionId    String
  region      Region  @relation(fields: [regionId], references: [id])
  bossEnemyId String
  bossEnemy   Enemy   @relation(fields: [bossEnemyId], references: [id])
}

model Item {
  id            String            @id @default(cuid())
  key           String            @unique
  name          String
  emoji         String
  slot          ItemSlot
  rarity        Rarity
  requiredLevel Int               @default(1)
  requiredStrength     Int      @default(0)
  requiredConstitution Int      @default(0)
  requiredIntelligence Int      @default(0)
  requiredDexterity    Int      @default(0)
  attack        Int               @default(0)
  defense       Int               @default(0)
  hp            Int               @default(0)
  speed         Int               @default(0)
  value         Int               @default(1)
  /** Short flavor text for tooltips. */
  description   String            @default("")
  /** Gold granted when sold at town shop. */
  sellPrice     Int               @default(0)
  inventoryRefs InventoryItem[]
  equipmentRefs CharacterEquipment[]
  lootEntries   LootTableEntry[]
}

model InventoryItem {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  quantity    Int       @default(1)
  /** Smithing tier for this stack (matches CharacterEquipment.forgeLevel when moved). */
  forgeLevel  Int       @default(0)
  /** Rolled prefix name for legendary/godly equipment stacks. */
  affixPrefix String?
  bonusLifeSteal Float  @default(0)
  bonusCritChance Float @default(0)
  bonusSkillPower Float @default(0)
  bonusStrength Int     @default(0)
  bonusConstitution Int @default(0)
  bonusIntelligence Int @default(0)
  bonusDexterity Int    @default(0)
  createdAt   DateTime  @default(now())

  @@unique([characterId, itemId, forgeLevel, affixPrefix, bonusLifeSteal, bonusCritChance, bonusSkillPower, bonusStrength, bonusConstitution, bonusIntelligence, bonusDexterity])
  @@index([characterId, itemId])
}

model CharacterEquipment {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  slot        ItemSlot
  itemId      String?
  item        Item?     @relation(fields: [itemId], references: [id])
  /** Smithing reinforcements on the piece in this slot (+N suffix, stat bonuses). */
  forgeLevel  Int       @default(0)
  affixPrefix String?
  bonusLifeSteal Float  @default(0)
  bonusCritChance Float @default(0)
  bonusSkillPower Float @default(0)
  bonusStrength Int     @default(0)
  bonusConstitution Int @default(0)
  bonusIntelligence Int @default(0)
  bonusDexterity Int    @default(0)

  @@unique([characterId, slot])
}

model LootTableEntry {
  id      String  @id @default(cuid())
  enemyId String
  enemy   Enemy   @relation(fields: [enemyId], references: [id], onDelete: Cascade)
  itemId  String
  item    Item    @relation(fields: [itemId], references: [id])
  chance  Float
}

model CombatLog {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  enemyId     String
  enemy       Enemy     @relation(fields: [enemyId], references: [id])
  outcome     String
  turns       Int
  log         Json
  xpGained    Int
  goldGained  Int
  createdAt   DateTime  @default(now())
}
